# Harden directory behavior and make sure requests are handled by Flask/Passenger.
Options -Indexes
DirectoryIndex passenger_wsgi.py

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Serve real files/directories directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Forward all route requests to the WSGI entrypoint.
  RewriteRule ^(.*)$ passenger_wsgi.py/$1 [QSA,L]
</IfModule>
